{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "channelsEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "Notion@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "crit@crit": true,
    "datadog@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "honcho@honcho": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "crit": {
      "source": {
        "repo": "tomasz-tomczyk/crit",
        "source": "github"
      }
    },
    "honcho": {
      "source": {
        "repo": "plastic-labs/claude-honcho",
        "source": "github"
      }
    },
    "obsidian-skills": {
      "source": {
        "repo": "kepano/obsidian-skills",
        "source": "github"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754085701509
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/kadoppe/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/stop-send-notification.mjs",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "claude-fable-5[1m]",
  "remoteControlAtStartup": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.py",
    "type": "command"
  },
  "tui": "default"
}
